  if (gastroScreenSessions.get(key)) return reply;
  if (!isGastroTopic(message)) return reply;

  gastroOfferSessions.set(key, true);
  return (
    `${reply}\n\n` +
    'Do you want a quick gastro symptom screening to estimate risk? Reply Yes to start.'
  );
